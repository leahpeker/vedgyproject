# Local Development (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://vedgy:vedgy@localhost:5432/vedgy
DEBUG=True

# Production Configuration
# SECRET_KEY=your-secret-key-here-generate-a-random-string
# DATABASE_URL=postgresql://username:password@host:port/database

# Backblaze B2 Storage — leave empty to use local filesystem (photos stored in backend/media/)
# Fill in real values to enable B2 uploads. All four must be set or all left empty.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_ID=
B2_BUCKET_NAME=
